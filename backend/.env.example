# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./flyertrack.db

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Default admin account (created on first run)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email alerts (optional, Gmail SMTP)
EMAIL_USER=
EMAIL_PASS=

# Public base URL
BASE_URL=http://localhost:3000
